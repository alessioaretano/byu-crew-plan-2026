function rd(n){
  const p = PACE[(n-1)%24];
  const nu= NUT[(n-1)%48];
  const d = new Date(START.getTime()+(n-1)*3600000);
  const h0= d.getHours().toString().padStart(2,'0');
  const h1= ((d.getHours()+1)%24).toString().padStart(2,'0');
  return {n,dayNum:Math.floor((n-1)/24)+1,wd:WD[d.getDay()],dt:`${d.getDate()}. ${MO[d.getMonth()]}`,
    t0:`${h0}:00`,t1:`${h1}:00`,startMs:d.getTime(),...p,...nu};
}

// ═══ STATE ═══
let curRound = parseInt(localStorage.getItem('byu_rd')||'1');
let autoMode = false;
let planFilter = 'all';
let planDay = 0;
let curTab = 0;

// ═══ AUTO-DETECT ═══
function detectRound(){
  const now = Date.now();
  if(now < START.getTime()) return null;
  const elapsed = (now - START.getTime())/3600000;
  if(elapsed >= 120) return 120;
  return Math.floor(elapsed)+1;
}
function syncToTime(){
  const r = detectRound();
  if(r){ curRound=r; autoMode=true; save(); renderJetzt(); }
}
function disableAuto(){ autoMode=false; document.getElementById('auto-banner').classList.add('hidden'); }
function save(){ localStorage.setItem('byu_rd', curRound); }

// ═══ TAB NAVIGATION ═══
function goTab(i){
  curTab=i;
  document.getElementById('swiper').style.transform=`translateX(-${i*25}%)`;
  document.querySelectorAll('.nav-btn').forEach(b=>b.classList.toggle('active',+b.dataset.tab===i));
}

// swipe
let tx=0,ty=0,dragging=false;
const sw=document.getElementById('swiper');
sw.addEventListener('touchstart',e=>{tx=e.touches[0].clientX;ty=e.touches[0].clientY;dragging=true;},{passive:true});
sw.addEventListener('touchend',e=>{
  if(!dragging)return; dragging=false;
  const dx=e.changedTouches[0].clientX-tx;
  const dy=e.changedTouches[0].clientY-ty;
  if(Math.abs(dx)>Math.abs(dy)*1.5&&Math.abs(dx)>40){
    if(dx<0&&curTab<3) goTab(curTab+1);
    else if(dx>0&&curTab>0) goTab(curTab-1);
  }
},{passive:true});

// ═══ JETZT ═══
function renderJetzt(){
  const r = rd(curRound);
  const now = Date.now();

  // hero
  document.getElementById('h-rd').textContent = curRound;
  document.getElementById('h-phase').textContent = r.phase;
  const hp = document.getElementById('h-pace');
  hp.textContent = r.pace + ' · ' + r.ziel;
  hp.className = 'hero-pace ' + r.pace;
  document.getElementById('h-time').textContent = `${r.t0} – ${r.t1}`;

  // prep
  document.getElementById('prep-rd').textContent = curRound;
  document.getElementById('prep-flasche').textContent = r.f === 'Wasser' ? 'Wasser 💧' : 'MNSTRY ' + r.f;
  document.getElementById('prep-essen').textContent = r.e;
  const elRow = document.getElementById('prep-elek-row');
  if(r.el === '–'){
    document.getElementById('prep-elek').innerHTML = '<span style="color:var(--dim)">Keine</span>';
  } else {
    document.getElementById('prep-elek').innerHTML = `<span class="elek-pill">${r.el}</span>`;
  }
  // Reset prep checks when round changes
  document.querySelectorAll('.prep-row').forEach(row => row.classList.remove('done'));

  // nap
  document.getElementById('nap-alert').classList.toggle('hidden',!r.nap);

  // next round
  const next = curRound < 120 ? rd(curRound+1) : null;
  document.getElementById('next-rd-num').textContent = curRound+1;
  if(next){
    document.getElementById('next-flasche').textContent = next.f === 'Wasser' ? 'Wasser 💧' : 'MNSTRY '+next.f;
    document.getElementById('next-essen').textContent = next.e;
    document.getElementById('next-card').style.display='';
  } else {
    document.getElementById('next-card').style.display='none';
  }

  // countdown
  renderCountdown();

  // upcoming (next 5 after current)
  let upHtml='';
  for(let i=1;i<=5;i++){
    const nn=curRound+i;
    if(nn>120)break;
    const rr=rd(nn);
    upHtml+=`<div class="upcoming-item">
      <div class="uprd">${nn}</div>
      <div class="uptime">${rr.t0}</div>
      <div class="updot ${rr.pace}"></div>
      <div class="upfood">${rr.e}</div>
      ${rr.nap?'<div class="upnap">💤</div>':''}
    </div>`;
  }
  document.getElementById('upcoming-list').innerHTML=upHtml;

  // auto banner
  const detected = detectRound();
  if(detected && autoMode){
    document.getElementById('auto-banner').classList.remove('hidden');
  }

  // prerace
  const pr = document.getElementById('prerace-box');
  if(Date.now() < START.getTime()){
    pr.classList.remove('hidden');
  } else {
    pr.classList.add('hidden');
  }

  // update plan current highlight
  document.querySelectorAll('.rcard').forEach(c=>{
    const n=parseInt(c.dataset.round);
    c.classList.toggle('is-current',n===curRound);
    c.classList.toggle('is-done',n<curRound);
  });
}

function togglePrep(el){
  el.classList.toggle('done');
}

function fmtMin(ms){
  if(ms<=0)return '0:00';
  const m=Math.floor(ms/60000);
  const s=Math.floor((ms%60000)/1000);
  return `${m}:${s.toString().padStart(2,'0')}`;
}

function changeRound(d){
  autoMode=false;
  curRound=Math.max(1,Math.min(120,curRound+d));
  save(); renderJetzt();
}

// ═══ PLAN ═══
