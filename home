<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <title>BYU 2026 · Crew</title>
  <style>
    :root {
      --bg:#000; --surface:#0D0D0D; --card:#141414; --card2:#1C1C1C;
      --border:#1E1E1E; --border2:#2A2A2A;
      --text:#F0E6D8; --dim:#52493E; --mid:#8A7E70; --cream:#F0E6D8;
      --s-bg:#1A0808; --s-acc:#E05050; --s-txt:#FF9090; --s-bd:#5C1C1C;
      --m-bg:#081408; --m-acc:#3DA85A; --m-txt:#7DD88A; --m-bd:#1C4C22;
      --r-bg:#180C00; --r-acc:#D86818; --r-txt:#FFB060; --r-bd:#5A2C08;
      --nap:#9060C8; --nap-txt:#C090FF;
      --top:52px; --bot:64px;
    }
    *{box-sizing:border-box;margin:0;padding:0;}
    html,body{height:100%;overflow:hidden;background:var(--bg);}
    body{color:var(--text);font-family:-apple-system,BlinkMacSystemFont,'SF Pro Text',system-ui,sans-serif;font-size:16px;line-height:1.45;-webkit-font-smoothing:antialiased;user-select:none;-webkit-tap-highlight-color:transparent;}

    /* TOP BAR */
    .top-bar{position:fixed;top:0;left:0;right:0;height:var(--top);background:var(--surface);border-bottom:1px solid var(--border);z-index:100;display:flex;align-items:center;justify-content:space-between;padding:0 16px;padding-top:env(safe-area-inset-top);}
    .brand{font-family:Georgia,serif;font-size:16px;font-weight:700;color:var(--cream);letter-spacing:-.5px;}
    .top-right{text-align:right;}
    .live-clock{font-size:18px;font-weight:600;color:var(--cream);font-variant-numeric:tabular-nums;letter-spacing:-.5px;}
    .race-day{font-size:10px;color:var(--dim);text-transform:uppercase;letter-spacing:.07em;}

    /* BOTTOM NAV */
    .bottom-nav{position:fixed;bottom:0;left:0;right:0;height:var(--bot);background:var(--surface);border-top:1px solid var(--border);z-index:100;display:flex;padding-bottom:env(safe-area-inset-bottom);}
    .nav-btn{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:2px;background:none;border:none;color:var(--dim);cursor:pointer;min-height:44px;transition:color .15s;}
    .nav-btn.active{color:var(--cream);}
    .nav-icon{font-size:22px;line-height:1;}
    .nav-label{font-size:10px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;}

    /* CONTENT */
    .content{position:fixed;top:var(--top);bottom:var(--bot);left:0;right:0;overflow:hidden;}
    .swiper{display:flex;width:400%;height:100%;transition:transform .32s cubic-bezier(.25,.46,.45,.94);will-change:transform;}
    .tab{width:25%;height:100%;overflow-y:auto;overflow-x:hidden;-webkit-overflow-scrolling:touch;}

    /* ── JETZT TAB ── */
    .hero{padding:20px 16px 0;}
    .hero-top{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:12px;}
    .hero-rd{font-size:80px;font-weight:800;line-height:1;letter-spacing:-4px;color:var(--cream);}
    .hero-meta{text-align:right;padding-top:8px;}
    .hero-phase{font-size:11px;color:var(--dim);text-transform:uppercase;letter-spacing:.08em;margin-bottom:6px;}
    .hero-pace{display:inline-flex;align-items:center;padding:7px 16px;border-radius:24px;font-size:14px;font-weight:700;letter-spacing:.04em;}
    .hero-pace.SCHNELL{background:var(--s-bg);color:var(--s-txt);border:1px solid var(--s-bd);}
    .hero-pace.MITTEL {background:var(--m-bg);color:var(--m-txt);border:1px solid var(--m-bd);}
    .hero-pace.RECOVERY{background:var(--r-bg);color:var(--r-txt);border:1px solid var(--r-bd);}
    .hero-time{font-size:15px;color:var(--mid);margin-top:4px;}

    /* countdown */
    .countdown-box{margin:0 16px 14px;background:var(--card);border:1px solid var(--border2);border-radius:14px;padding:14px 16px;display:flex;align-items:center;justify-content:space-between;}
    .cd-left .cd-lbl{font-size:11px;text-transform:uppercase;letter-spacing:.07em;color:var(--dim);}
    .cd-left .cd-time{font-size:32px;font-weight:800;font-variant-numeric:tabular-nums;color:var(--cream);line-height:1.1;}
    .cd-left .cd-sub{font-size:12px;color:var(--mid);margin-top:2px;}
    .cd-right{text-align:right;}
    .cd-next-lbl{font-size:10px;color:var(--dim);text-transform:uppercase;letter-spacing:.07em;}
    .cd-next-time{font-size:15px;font-weight:700;color:var(--cream);font-variant-numeric:tabular-nums;}

    /* nap alert */
    .nap-alert{margin:0 16px 14px;background:rgba(144,96,200,.14);border:1px solid rgba(144,96,200,.4);border-radius:14px;padding:14px 16px;display:flex;align-items:center;gap:12px;}
    .nap-alert .nap-ico{font-size:28px;}
    .nap-alert strong{display:block;font-size:15px;color:var(--nap-txt);font-weight:700;}
    .nap-alert span{font-size:13px;color:var(--mid);}

    /* prep section */
    .prep{padding:0 16px 16px;}
    .prep-lbl{font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--dim);margin-bottom:10px;display:flex;align-items:center;gap:8px;}
    .prep-lbl::after{content:'';flex:1;height:1px;background:var(--border);}
    .prep-card{background:var(--card);border-radius:14px;border:1px solid var(--border2);margin-bottom:12px;overflow:hidden;}
    .prep-row{display:flex;align-items:flex-start;gap:12px;padding:13px 16px;border-bottom:1px solid var(--border);cursor:pointer;transition:background .1s;}
    .prep-row:active{background:var(--border);}
    .prep-row.done{opacity:0.4;}
    .prep-row.done .prep-item-val{text-decoration:line-through;}
    .prep-row:last-child{border-bottom:none;}
    .prep-ico{font-size:20px;width:26px;text-align:center;flex-shrink:0;}
    .prep-content{flex:1;}
    .prep-content .prep-item-lbl{font-size:11px;color:var(--dim);text-transform:uppercase;letter-spacing:.06em;margin-bottom:2px;}
    .prep-content .prep-item-val{font-size:16px;color:var(--text);font-weight:500;}
    .prep-content .prep-item-val.big{font-size:17px;color:var(--cream);font-weight:700;}
    .prep-check{width:20px;height:20px;border:1px solid var(--border2);border-radius:4px;display:flex;align-items:center;justify-content:center;font-size:14px;color:var(--m-acc);margin-top:8px;}
    .prep-row.done .prep-check{background:var(--m-bg);border-color:var(--m-bd);}
    .elek-pill{display:inline-block;background:rgba(253,224,71,.1);color:#FDE047;border:1px solid rgba(253,224,71,.22);border-radius:6px;padding:3px 9px;font-size:13px;font-weight:600;}

    /* upcoming */
    .upcoming{padding:0 16px 24px;}
    .upcoming-item{display:flex;align-items:center;gap:10px;padding:11px 0;border-bottom:1px solid var(--border);}
    .upcoming-item:last-child{border-bottom:none;}
    .uprd{font-size:13px;font-weight:700;color:var(--dim);width:30px;flex-shrink:0;}
    .uptime{font-size:13px;color:var(--mid);width:48px;font-variant-numeric:tabular-nums;flex-shrink:0;}
    .updot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
    .updot.SCHNELL{background:var(--s-acc);}
    .updot.MITTEL {background:var(--m-acc);}
    .updot.RECOVERY{background:var(--r-acc);}
    .upfood{flex:1;font-size:13px;color:var(--mid);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
    .upnap{color:var(--nap-txt);font-size:12px;flex-shrink:0;}

    /* round controls */
    .rd-controls{display:flex;align-items:center;gap:16px;padding:16px;border-top:1px solid var(--border);}
    .rdc-btn{background:var(--card);border:1px solid var(--border2);border-radius:50%;width:52px;height:52px;display:flex;align-items:center;justify-content:center;font-size:26px;color:var(--cream);cursor:pointer;flex-shrink:0;transition:transform .1s,background .1s;}
    .rdc-btn:active{transform:scale(.9);background:var(--border2);}
    .rdc-center{flex:1;text-align:center;}
    .rdc-lbl{font-size:11px;color:var(--dim);text-transform:uppercase;letter-spacing:.07em;}
    .rdc-sync{background:none;border:1px solid var(--border2);border-radius:8px;color:var(--mid);font-size:12px;padding:7px 13px;cursor:pointer;margin-top:6px;}
    .rdc-sync:active{background:var(--border);}

    /* auto banner */
    .auto-banner{margin:0 16px 14px;background:rgba(61,168,90,.1);border:1px solid rgba(61,168,90,.25);border-radius:10px;padding:10px 14px;font-size:13px;color:var(--m-txt);display:flex;align-items:center;justify-content:space-between;gap:8px;}
    .auto-banner button{background:none;border:none;color:var(--m-acc);font-size:12px;cursor:pointer;white-space:nowrap;}
    .auto-banner.hidden{display:none;}

    /* prerace */
    .prerace{margin:16px;background:rgba(216,104,24,.08);border:1px solid rgba(216,104,24,.3);border-radius:14px;padding:24px;text-align:center;}
    .prerace .pr-lbl{font-size:11px;color:var(--dim);text-transform:uppercase;letter-spacing:.07em;margin-bottom:8px;}
    .prerace .pr-time{font-size:32px;font-weight:800;color:var(--r-txt);font-variant-numeric:tabular-nums;line-height:1.1;}
    .prerace .pr-sub{font-size:13px;color:var(--mid);margin-top:8px;}

    /* ── PLAN TAB ── */
    .plan-sticky{position:sticky;top:0;z-index:10;background:var(--bg);padding:12px 16px;border-bottom:1px solid var(--border);}
    .day-scroll{display:flex;gap:6px;overflow-x:auto;scrollbar-width:none;-webkit-overflow-scrolling:touch;margin-bottom:10px;}
    .day-scroll::-webkit-scrollbar{display:none;}
    .day-chip{flex-shrink:0;background:var(--card);border:1px solid var(--border);border-radius:20px;padding:6px 14px;font-size:12px;font-weight:600;color:var(--mid);cursor:pointer;white-space:nowrap;transition:all .15s;}
    .day-chip.active{background:var(--cream);color:#000;border-color:var(--cream);}
    .pace-filters{display:flex;gap:6px;}
    .pf{flex:1;border-radius:8px;padding:8px 4px;font-size:11px;font-weight:700;letter-spacing:.04em;text-align:center;cursor:pointer;border:1px solid transparent;transition:all .15s;}
    .pf[data-f="all"]{background:var(--card);border-color:var(--border2);color:var(--mid);}
    .pf[data-f="all"].active{background:var(--cream);color:#000;}
    .pf[data-f="SCHNELL"]{background:var(--s-bg);border-color:var(--s-bd);color:var(--s-txt);}
    .pf[data-f="SCHNELL"].active{background:var(--s-acc);color:#fff;border-color:var(--s-acc);}
    .pf[data-f="MITTEL"]{background:var(--m-bg);border-color:var(--m-bd);color:var(--m-txt);}
    .pf[data-f="MITTEL"].active{background:var(--m-acc);color:#fff;border-color:var(--m-acc);}
    .pf[data-f="RECOVERY"]{background:var(--r-bg);border-color:var(--r-bd);color:var(--r-txt);}
    .pf[data-f="RECOVERY"].active{background:var(--r-acc);color:#fff;border-color:var(--r-acc);}

    .rounds-list{padding:0 16px 32px;}
    .day-hdr{font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--dim);padding:16px 0 8px;}
    .rcard{background:var(--card);border-radius:12px;padding:13px 14px;margin-bottom:8px;border:1px solid var(--border);border-left:3px solid transparent;transition:opacity .2s;}
    .rcard.SCHNELL{border-left-color:var(--s-acc);background:var(--s-bg);}
    .rcard.MITTEL {border-left-color:var(--m-acc);background:var(--m-bg);}
    .rcard.RECOVERY{border-left-color:var(--r-acc);background:var(--r-bg);}
    .rcard.is-current{outline:2px solid var(--cream);outline-offset:1px;}
    .rcard.is-done{opacity:.4;}
    .rcard.hidden{display:none;}
    .rcard-top{display:flex;align-items:center;gap:8px;margin-bottom:9px;}
    .rc-num{font-size:18px;font-weight:800;color:var(--dim);min-width:30px;}
    .rcard.is-current .rc-num{color:var(--cream);}
    .rc-time{font-size:14px;font-weight:600;color:var(--mid);font-variant-numeric:tabular-nums;}
    .rc-phase{font-size:11px;color:var(--dim);text-transform:uppercase;letter-spacing:.06em;}
    .rc-sp{flex:1;}
    .rc-pace{font-size:11px;font-weight:700;letter-spacing:.04em;padding:3px 8px;border-radius:6px;}
    .rc-pace.SCHNELL{background:var(--s-bg);color:var(--s-txt);}
    .rc-pace.MITTEL {background:var(--m-bg);color:var(--m-txt);}
    .rc-pace.RECOVERY{background:var(--r-bg);color:var(--r-txt);}
    .rc-nap{font-size:14px;}
    .rcard-body{display:grid;gap:6px;}
    .rc-row{display:flex;justify-content:space-between;font-size:13px;}
    .rc-lbl{color:var(--dim);}
    .rc-val{color:var(--text);font-weight:500;}
    .rc-elek{color:#FDE047;font-weight:600;}
    .rc-hint{font-size:12px;color:var(--mid);margin-top:4px;padding-top:6px;border-top:1px solid rgba(255,255,255,0.05);font-style:italic;}

    /* ── CREW TAB ── */
    .crew-pad{padding:16px;}
    .sec-title{font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--dim);margin:24px 0 12px;display:flex;align-items:center;gap:8px;}
    .sec-title:first-child{margin-top:0;}
    .sec-title::after{content:'';flex:1;height:1px;background:var(--border);}
    .info-card{background:var(--card);border:1px solid var(--border2);border-radius:14px;padding:4px 0;margin-bottom:16px;}
    .check-row, .rule-row{display:flex;align-items:flex-start;gap:12px;padding:12px 16px;border-bottom:1px solid var(--border);font-size:14px;}
    .check-row:last-child, .rule-row:last-child{border-bottom:none;}
    .chk{width:20px;height:20px;border:1px solid var(--border2);border-radius:4px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:14px;color:var(--m-acc);margin-top:1px;}
    .check-row.done{color:var(--dim);}
    .check-row.done .chk{background:var(--m-bg);border-color:var(--m-bd);}
    .check-row.done span{text-decoration:line-through;}
    .rule-dash{color:var(--mid);font-weight:700;flex-shrink:0;}
    .motto-card{background:linear-gradient(135deg, #1a0808 0%, #000 100%);border:1px solid var(--s-bd);border-radius:14px;padding:20px;text-align:center;margin-bottom:20px;}
    .motto-txt{font-family:Georgia,serif;font-size:20px;font-style:italic;color:var(--s-txt);font-weight:700;}

    /* ── NAP TAB ── */
    .nap-pad{padding:16px;}
    .nap-night-hdr{font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--dim);margin:20px 0 10px;}
    .nap-row{display:flex;align-items:center;gap:12px;padding:12px 14px;background:var(--card);border:1px solid var(--border2);border-radius:10px;margin-bottom:6px;}
    .nap-row.window{border-color:rgba(144,96,200,0.3);background:rgba(144,96,200,0.05);}
    .nap-rd-time{width:55px;flex-shrink:0;}
    .nrt-rd{font-size:11px;color:var(--dim);font-weight:700;}
    .nrt-t{font-size:14px;color:var(--cream);font-weight:700;}
    .nap-desc{flex:1;font-size:13px;color:var(--mid);}
    .nap-tag{background:var(--nap);color:#fff;font-size:10px;font-weight:800;padding:3px 7px;border-radius:4px;letter-spacing:.04em;}
    .koffein-card{background:#1A1A08;border:1px solid #444414;border-radius:14px;padding:16px;margin-top:12px;}
    .koffein-card h3{font-size:14px;color:#FDE047;margin-bottom:10px;text-transform:uppercase;letter-spacing:.05em;}

    /* QR MODAL */
    .qr-modal{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.9);z-index:1000;display:none;align-items:center;justify-content:center;padding:20px;}
    .qr-inner{background:var(--surface);border:1px solid var(--border2);border-radius:24px;padding:32px 24px;width:100%;max-width:340px;text-align:center;position:relative;}
    .qr-close{position:absolute;top:16px;right:16px;width:32px;height:32px;background:var(--card);border:1px solid var(--border2);border-radius:50%;color:var(--mid);font-size:20px;display:flex;align-items:center;justify-content:center;}
    .qr-ttl{font-size:18px;font-weight:700;color:var(--cream);margin-bottom:4px;}
    .qr-sub{font-size:13px;color:var(--dim);margin-bottom:24px;}
    .qr-img{margin-bottom:24px;display:flex;justify-content:center;}
    .qr-url{font-size:11px;color:var(--mid);word-break:break-all;background:var(--card);padding:10px;border-radius:8px;margin-bottom:16px;}
    .qr-note{font-size:12px;color:var(--dim);line-height:1.5;}
    .qr-public{margin-top:12px;font-size:11px;color:var(--mid);padding-top:12px;border-top:1px solid var(--border);}

    .hidden{display:none;}
  </style>
</head>
<body>

<div class="top-bar">
  <div class="brand">WITIKON BYU 2026</div>
  <div class="top-right">
    <div class="live-clock" id="live-clock">00:00:00</div>
    <div class="race-day" id="race-day-lbl">Tag 1 · Witikon</div>
  </div>
</div>

<div class="content">
  <div class="swiper" id="swiper">

    <!-- ═══ TAB 0: JETZT ═══ -->
    <div class="tab" id="tab-jetzt">
      
      <div id="prerace-box" class="prerace hidden">
        <div class="pr-lbl">Rennen Starten in:</div>
        <div class="pr-time" id="prerace-time">00:00:00</div>
        <div class="pr-sub" id="race-status">Vor dem Start</div>
      </div>

      <div class="hero">
        <div class="hero-top">
          <div class="hero-rd" id="h-rd">1</div>
          <div class="hero-meta">
            <div class="hero-phase" id="h-phase">Tag</div>
            <div class="hero-pace RECOVERY" id="h-pace">RECOVERY · 53–55 min</div>
            <div class="hero-time" id="h-time">12:00 – 13:00</div>
          </div>
        </div>
      </div>

      <div class="countdown-box">
        <div class="cd-left">
          <div class="cd-lbl" id="cd-lbl">Läufer kommt zurück in ca.</div>
          <div class="cd-time" id="cd-time">00:00</div>
          <div class="cd-sub" id="cd-sub">RECOVERY · ca. 54 min</div>
        </div>
        <div class="cd-right">
          <div class="cd-next-lbl">Nächster Start</div>
          <div class="cd-next-time" id="cd-next">13:00 Uhr</div>
        </div>
      </div>

      <div id="auto-banner" class="auto-banner hidden">
        <span>⏱ Zeit-Sync aktiv (Auto-Runde)</span>
        <button onclick="disableAuto()">Stoppen</button>
      </div>

      <div id="nap-alert" class="nap-alert hidden">
        <div class="nap-ico">💤</div>
        <div>
          <strong>Nap-Fenster offen!</strong>
          <span>Schnelle Runde → 15 min Schlaf möglich.</span>
        </div>
      </div>

      <!-- prep current -->
      <div class="prep">
        <div class="prep-lbl">Runde <span id="prep-rd">1</span> – Jetzt bereitstellen</div>
        <div class="prep-card">
          <div class="prep-row" onclick="togglePrep(this)">
            <div class="prep-ico">🥤</div>
            <div class="prep-content">
              <div class="prep-item-lbl">Flasche 500ml</div>
              <div class="prep-item-val big" id="prep-flasche">—</div>
            </div>
            <div class="prep-check"></div>
          </div>
          <div class="prep-row" onclick="togglePrep(this)">
            <div class="prep-ico">🍽️</div>
            <div class="prep-content">
              <div class="prep-item-lbl">Essen in der Pause</div>
              <div class="prep-item-val big" id="prep-essen">—</div>
            </div>
            <div class="prep-check"></div>
          </div>
          <div class="prep-row" id="prep-elek-row" onclick="togglePrep(this)">
            <div class="prep-ico">💊</div>
            <div class="prep-content">
              <div class="prep-item-lbl">Salz / Elektrolyt</div>
              <div class="prep-item-val" id="prep-elek">—</div>
            </div>
            <div class="prep-check"></div>
          </div>
        </div>
      </div>

      <!-- next round -->
      <div class="prep">
        <div class="prep-lbl">Nächste Runde <span id="next-rd-num">2</span> – vorbereiten</div>
        <div class="prep-card" id="next-card">
          <div class="prep-row">
            <div class="prep-ico">🥤</div>
            <div class="prep-content">
              <div class="prep-item-lbl">Flasche</div>
              <div class="prep-item-val" id="next-flasche">—</div>
            </div>
          </div>
          <div class="prep-row">
            <div class="prep-ico">🍽️</div>
            <div class="prep-content">
              <div class="prep-item-lbl">Essen</div>
              <div class="prep-item-val" id="next-essen">—</div>
            </div>
          </div>
        </div>
      </div>

      <!-- upcoming -->
      <div class="upcoming">
        <div class="prep-lbl">Vorschau</div>
        <div id="upcoming-list"></div>
      </div>

      <!-- controls -->
      <div class="rd-controls">
        <button class="rdc-btn" onclick="changeRound(-1)">−</button>
