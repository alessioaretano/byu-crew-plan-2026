    if(r.dayNum!==lastDay){
      html+=`<div class="day-hdr">${DAY_LABELS[r.dayNum]}</div>`;
      lastDay=r.dayNum;
    }
    const elHtml = r.el==='–' ? `<span style="color:var(--dim)">–</span>` : `<span class="rc-elek">${r.el}</span>`;
    html+=`<div class="rcard ${r.pace} ${n===curRound?'is-current':n<curRound?'is-done':''}" data-round="${n}" data-day="${r.dayNum}" data-pace="${r.pace}">
      <div class="rcard-top">
        <div class="rc-num">${n}</div>
        <div class="rc-time">${r.t0}</div>
        <div class="rc-phase">${r.phase}</div>
        <div class="rc-sp"></div>
        <div class="rc-pace ${r.pace}">${r.pace}</div>
        ${r.nap?'<div class="rc-nap">💤</div>':''}
      </div>
      <div class="rcard-body">
        <div class="rc-row"><div class="rc-lbl">Flasche</div><div class="rc-val">${r.f==='Wasser'?'Wasser 💧':'MNSTRY '+r.f}</div></div>
        <div class="rc-row"><div class="rc-lbl">Essen</div><div class="rc-val">${r.e}</div></div>
        <div class="rc-row"><div class="rc-lbl">Salz</div><div class="rc-val">${elHtml}</div></div>
        <div class="rc-hint">${r.hinweis}</div>
      </div>
    </div>`;
  }
  document.getElementById('rounds-list').innerHTML=html;
  applyPlanFilters();
}

function applyPlanFilters(){
  document.querySelectorAll('.rcard').forEach(c=>{
    const p=c.dataset.pace, d=parseInt(c.dataset.day);
    const ok=(planFilter==='all'||p===planFilter)&&(planDay===0||d===planDay);
    c.classList.toggle('hidden',!ok);
  });
  document.querySelectorAll('.day-hdr').forEach(h=>{
    let sib=h.nextElementSibling,hasVisible=false;
    while(sib&&!sib.classList.contains('day-hdr')){
      if(!sib.classList.contains('hidden'))hasVisible=true;
      sib=sib.nextElementSibling;
    }
    h.style.display=hasVisible?'':'none';
  });
}

function setDay(d){
  planDay=d;
  document.querySelectorAll('.day-chip').forEach(b=>b.classList.toggle('active',+b.dataset.day===d));
  applyPlanFilters();
}
function setFilter(f){
  planFilter=f;
  document.querySelectorAll('.pf').forEach(b=>b.classList.toggle('active',b.dataset.f===f));
  applyPlanFilters();
}

// ═══ CREW CHECKLIST ═══
