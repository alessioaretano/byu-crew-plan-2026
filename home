function resetChecklist(){ document.querySelectorAll('.check-row').forEach(r=>{r.classList.remove('done');r.querySelector('.chk').textContent='';}); }

// ═══ NAP TAB ═══
function buildNap(){
  const nights=[
    {label:'Nacht 1 – Do→Fr (21–06 Uhr)',rds:[10,11,12,13,14,15,16,17]},
    {label:'Nacht 2 – Fr→Sa (21–06 Uhr)',rds:[34,35,36,37,38,39,40,41]},
    {label:'Nacht 3 – Sa→So (21–06 Uhr)',rds:[58,59,60,61,62,63,64,65]},
    {label:'Nacht 4 – So→Mo (21–06 Uhr)',rds:[82,83,84,85,86,87,88,89]},
    {label:'Nacht 5 – Mo→Di (21–06 Uhr)',rds:[106,107,108,109,110,111,112,113]},
  ];
  let html='';
  nights.forEach(night=>{
    html+=`<div class="nap-night-hdr">${night.label}</div>`;
    night.rds.forEach(n=>{
      const r=rd(n);
      const isNap=r.nap;
      html+=`<div class="nap-row ${isNap?'window':''}">
        <div class="nap-rd-time"><div class="nrt-rd">Rd ${n}</div><div class="nrt-t">${r.t0}</div></div>
        <div class="nap-desc">${r.pace==='RECOVERY'?'Recovery – Essen, Dehnen':isNap?'Schnell → Nap möglich':'Schnell → Pause nutzen'}</div>
        ${isNap?'<div class="nap-tag">💤 NAP</div>':''}
      </div>`;
    });
  });
  document.getElementById('nap-nights').innerHTML=html;
}

// ═══ CLOCK + LIVE UPDATE ═══
function updateClock(){
  const now=new Date();
  const hh=now.getHours().toString().padStart(2,'0');
  const mm=now.getMinutes().toString().padStart(2,'0');
  const ss=now.getSeconds().toString().padStart(2,'0');
  document.getElementById('live-clock').textContent=`${hh}:${mm}:${ss}`;

  const elapsed=(now-START)/3600000;
  if(elapsed>=0&&elapsed<120){
    const dayN=Math.floor(elapsed/24)+1;
    document.getElementById('race-day-lbl').textContent=`Tag ${dayN} · Witikon`;
    document.getElementById('race-status').textContent=`Runde ${Math.floor(elapsed)+1} läuft`;
  } else if(elapsed<0){
    document.getElementById('race-status').textContent='Vor dem Start';
    // prerace countdown
    const ms=START-now;
    document.getElementById('prerace-time').textContent=fmtHMS(ms);
    document.getElementById('prerace-box').classList.remove('hidden');
  } else {
    document.getElementById('race-status').textContent='Rennen beendet';
  }

  // auto-mode: update curRound every 30s
  if(autoMode){
    const detected=detectRound();
    if(detected&&detected!==curRound){curRound=detected;save();renderJetzt();}
  }

  // refresh countdown every second
  if(curTab===0) renderCountdown();
}

function renderCountdown(){
  const r=rd(curRound);
  const now=Date.now();
  const next = curRound < 120 ? rd(curRound+1) : null;
  
  if(now < START.getTime()){
    // Vor dem Rennen
    const ms = START.getTime() - now;
    document.getElementById('cd-lbl').textContent = 'Rennen startet in';
    document.getElementById('cd-time').textContent = fmtHMS(ms);
    document.getElementById('cd-sub').textContent = 'Do 14. Mai · 12:00 Uhr';
    document.getElementById('cd-next').textContent = '12:00 Uhr';
    return;
  }

  const paceMin=r.pace==='SCHNELL'?43:r.pace==='MITTEL'?50:54;
  const expectedReturn=r.startMs+paceMin*60000;
  const msLeft=expectedReturn-now;
  
  if(now<r.startMs){
    document.getElementById('cd-lbl').textContent='Runde beginnt in';
    document.getElementById('cd-time').textContent=fmtMin(r.startMs-now);
    document.getElementById('cd-sub').textContent=`Startet um ${r.t0} Uhr`;
  } else if(msLeft>0){
    document.getElementById('cd-lbl').textContent='Läufer kommt zurück in ca.';
    document.getElementById('cd-time').textContent=fmtMin(msLeft);
    document.getElementById('cd-sub').textContent=`${r.pace} · ca. ${paceMin} min`;
  } else {
    document.getElementById('cd-lbl').textContent='Läufer erwartet';
    document.getElementById('cd-time').textContent='Jederzeit';
    document.getElementById('cd-sub').textContent='Nächste Runde um ' + (next?next.t0:'—');
  }
  document.getElementById('cd-next').textContent = next ? next.t0+' Uhr' : '—';
}

function fmtHMS(ms){
  const d=Math.floor(ms/86400000);
  const h=Math.floor((ms%86400000)/3600000);
  const m=Math.floor((ms%3600000)/60000);
  const s=Math.floor((ms%60000)/1000);
  
  if(d > 0) {
    return `${d}d ${h}:${m.toString().padStart(2,'0')}:${s.toString().padStart(2,'0')}`;
  }
  return `${h}:${m.toString().padStart(2,'0')}:${s.toString().padStart(2,'0')}`;
}

// ═══ QR ═══
function showQR(){
  const url=window.location.href;
  document.getElementById('qr-img').innerHTML=`<img src="https://api.qrserver.com/v1/create-qr-code/?size=200x200&data=${encodeURIComponent(url)}" width="200" height="200" style="display:block;border-radius:4px">`;
  document.getElementById('qr-url').textContent=url;
  document.getElementById('qr-modal').style.display='flex';
}
document.getElementById('qr-modal').addEventListener('click',function(e){if(e.target===this)this.style.display='none';});

// ═══ INIT ═══
const autoDetected=detectRound();
if(autoDetected){curRound=autoDetected;autoMode=true;save();}

buildPlan();
buildNap();
renderJetzt();
setInterval(updateClock,1000);
updateClock();
</script>
